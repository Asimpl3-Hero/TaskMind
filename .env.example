# ──────────────────────────────────────────────
#  Base de datos
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=taskmind
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ──────────────────────────────────────────────
#  OpenAI
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ──────────────────────────────────────────────
#  API / Backend
# ──────────────────────────────────────────────
CORS_ORIGINS=*
DB_ECHO=False

# ──────────────────────────────────────────────
#  Puertos (Docker Compose)
# ──────────────────────────────────────────────
DB_PORT=5432
API_PORT=8000
FRONTEND_PORT=8501
